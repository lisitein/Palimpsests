                                                   :hasTransformativeWork :Jin_Ping_Mei ;
                                                   :sourceElement :Outlaw_Hero_Ensemble_Focal ;
                                                   :targetElement :Merchant_Household_Focal ;
                                                   :rationale "The narrative focus shifts from a rotating ensemble of outlaw heroes to the enclosed interior of a single merchant household." ;
                                                   rdfs:label "Op_Water_Margin_to_Jin_Ping_Mei_FocalizationShift" .


###  http://example.org/palimpsests#Op_Water_Margin_to_Jin_Ping_Mei_PanJinLianReinterpretation
:Op_Water_Margin_to_Jin_Ping_Mei_PanJinLianReinterpretation rdf:type owl:NamedIndividual ,
                                                                     :Transformation ;
                                                            :hasOriginalWork :Water_Margin ;
