                                                          rdfs:label "Op_The_Three_Body_Problem_to_ThreeBodyX_WorldInheritance" .


###  http://example.org/palimpsests#Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_ContentDomainShift
:Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_ContentDomainShift rdf:type owl:NamedIndividual ,
                                                                          :Transformation ;
                                                                 :hasOriginalWork :The_Twilight_Saga ;
                                                                 :hasTransformativeWork :Fifty_Shades_of_Grey ;
                                                                 :sourceElement :Abstinent_Supernatural_Romance ;
                                                                 :targetElement :Explicit_Eroticism ;
                                                                 :rationale "The content domain is inverted: the source's abstinence theme becomes explicit eroticism as the central narrative material." ;
                                                                 rdfs:label "Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_ContentDomainShift" .


###  http://example.org/palimpsests#Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_HeroArchetypeImitation
:Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_HeroArchetypeImitation rdf:type owl:NamedIndividual ,
                                                                              :Imitation ;
                                                                     :hasOriginalWork :The_Twilight_Saga ;
                                                                     :hasTransformativeWork :Fifty_Shades_of_Grey ;
                                                                     :sourceElement :PowerfulDangerousHero_Vampire ;
                                                                     :targetElement :PowerfulDangerousHero_Tycoon ;
                                                                     :rationale "The dangerous-male-lead archetype is reused, but the source of danger is relocated from the supernatural (vampirism) to the psychological (childhood trauma); the 'darkness' is retained while its explanatory frame becomes realist." ;
                                                                     rdfs:label "Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_HeroArchetypeImitation" .


###  http://example.org/palimpsests#Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_PowerStructureInheritance
:Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_PowerStructureInheritance rdf:type owl:NamedIndividual ,
                                                                                 :Inheritance ;
                                                                        :hasOriginalWork :The_Twilight_Saga ;
                                                                        :hasTransformativeWork :Fifty_Shades_of_Grey ;
                                                                        :sourceElement :Dominant_Male_Submissive_Female ;
                                                                        :targetElement :Dominant_Male_Submissive_Female ;
                                                                        :rationale "The asymmetric dominant-male / submissive-female relational dynamic, together with the heroine's redeem-him-through-love arc, is inherited from the source." ;
                                                                        rdfs:label "Op_The_Twilight_Saga_to_Fifty_Shades_of_Grey_PowerStructureInheritance" .


###  http://example.org/palimpsests#Op_The_Wonderful_Wizard_of_Oz_to_Wicked_CharacterImitation
