@prefix : <http://example.org/palimpsests#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix creon: <http://www.ontologydesignpatterns.org/ont/creativity/creon.owl#> .
@base <http://example.org/palimpsests#> .

<http://example.org/palimpsests> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://example.org/palimpsests#externalRef
:externalRef rdf:type owl:AnnotationProperty ;
             rdfs:label "external reference" .


###  http://example.org/palimpsests#rationale
:rationale rdf:type owl:AnnotationProperty ;
           rdfs:label "rationale" .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/palimpsests#actsOnElement
:actsOnElement rdf:type owl:ObjectProperty ;
               rdfs:domain :CreativeStrategy ;
               rdfs:range :NarrativeElement .


###  http://example.org/palimpsests#elementOfWork
:elementOfWork rdf:type owl:ObjectProperty ;
               owl:inverseOf :hasNarrativeElement ;
               rdfs:domain :NarrativeElement ;
               rdfs:range :Work .


###  http://example.org/palimpsests#hasNarrativeElement
:hasNarrativeElement rdf:type owl:ObjectProperty ;
                     rdfs:domain :Work ;
                     rdfs:range :NarrativeElement .


###  http://example.org/palimpsests#hasOriginalWork
:hasOriginalWork rdf:type owl:ObjectProperty ;
                 rdfs:domain :CreativeStrategy ;
                 rdfs:range :Work .


###  http://example.org/palimpsests#hasTransformativeWork
:hasTransformativeWork rdf:type owl:ObjectProperty ;
                       rdfs:domain :CreativeStrategy ;
                       rdfs:range :Work .


###  http://example.org/palimpsests#sourceElement
:sourceElement rdf:type owl:ObjectProperty ;
               rdfs:domain :CreativeStrategy ;
               rdfs:range :NarrativeElement .


###  http://example.org/palimpsests#targetElement
:targetElement rdf:type owl:ObjectProperty ;
               rdfs:domain :CreativeStrategy ;
               rdfs:range :NarrativeElement .


#################################################################
#    Classes
#################################################################

###  http://example.org/palimpsests#BackgroundSetting
:BackgroundSetting rdf:type owl:Class ;
                   rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#Causality
:Causality rdf:type owl:Class ;
           rdfs:subClassOf :StoryStructure .


###  http://example.org/palimpsests#Character
:Character rdf:type owl:Class ;
           rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#CharacterArc
:CharacterArc rdf:type owl:Class ;
              rdfs:subClassOf :Character .


###  http://example.org/palimpsests#CharacterFunction
:CharacterFunction rdf:type owl:Class ;
                   rdfs:subClassOf :Character .


###  http://example.org/palimpsests#CharacterIdentity
:CharacterIdentity rdf:type owl:Class ;
                   rdfs:subClassOf :Character .


###  http://example.org/palimpsests#Chronotope
:Chronotope rdf:type owl:Class ;
            rdfs:subClassOf :BackgroundSetting .


###  http://example.org/palimpsests#ContentDomain
:ContentDomain rdf:type owl:Class ;
               rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#CreativeStrategy
:CreativeStrategy rdf:type owl:Class .


###  http://example.org/palimpsests#EventSequence
:EventSequence rdf:type owl:Class ;
               rdfs:subClassOf :StoryStructure .


###  http://example.org/palimpsests#Focalization
:Focalization rdf:type owl:Class ;
              rdfs:subClassOf :StoryStructure .


###  http://example.org/palimpsests#Imitation
:Imitation rdf:type owl:Class ;
           rdfs:subClassOf :CreativeStrategy .


###  http://example.org/palimpsests#Inheritance
:Inheritance rdf:type owl:Class ;
             rdfs:subClassOf :CreativeStrategy .


###  http://example.org/palimpsests#MediumType
:MediumType rdf:type owl:Class ;
            rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#NarrativeElement
:NarrativeElement rdf:type owl:Class .


###  http://example.org/palimpsests#Outcome
:Outcome rdf:type owl:Class ;
         rdfs:subClassOf :StoryStructure .


###  http://example.org/palimpsests#Relation
:Relation rdf:type owl:Class ;
          rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#RelationTopology
:RelationTopology rdf:type owl:Class ;
                  rdfs:subClassOf :Relation .


###  http://example.org/palimpsests#RelationType
:RelationType rdf:type owl:Class ;
              rdfs:subClassOf :Relation .


###  http://example.org/palimpsests#StoryStructure
:StoryStructure rdf:type owl:Class ;
                rdfs:subClassOf :NarrativeElement .


###  http://example.org/palimpsests#Transformation
:Transformation rdf:type owl:Class ;
                rdfs:subClassOf :CreativeStrategy .


###  http://example.org/palimpsests#Work
:Work rdf:type owl:Class ;
      owl:equivalentClass creon:CreativeProduct .


###  http://example.org/palimpsests#WorldRules
:WorldRules rdf:type owl:Class ;
            rdfs:subClassOf :BackgroundSetting .


###  http://www.ontologydesignpatterns.org/ont/creativity/creon.owl#CreativeProduct
creon:CreativeProduct rdf:type owl:Class .


