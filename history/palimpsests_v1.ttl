                                                           :hasOriginalWork :The_Wonderful_Wizard_of_Oz ;
                                                           :hasTransformativeWork :Wicked ;
                                                           :sourceElement :Wicked_Witch_as_Evil ;
                                                           :targetElement :Sympathetic_Elphaba ;
                                                           :rationale "The fixed villain is elevated to protagonist and given a sympathetic backstory, deconstructing the good-versus-evil binary and adding reflection on propaganda and prejudice." ;
                                                           rdfs:label "Op_The_Wonderful_Wizard_of_Oz_to_Wicked_VillainSubversion" .


###  http://example.org/palimpsests#Op_The_Wonderful_Wizard_of_Oz_to_Wicked_WorldInheritance
