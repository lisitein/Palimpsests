                                                              :hasTransformativeWork :Elementary ;
                                                              :sourceElement :Occasional_Drug_Use_Detail ;
                                                              :targetElement :Recovering_Addict_Arc ;
                                                              :rationale "A minor canonical detail (Holmes's drug use) is amplified into the protagonist's defining arc as a recovering addict." ;
                                                              rdfs:label "Op_Canon_of_Sherlock_Holmes_to_Elementary_HolmesAddictionArc" .


###  http://example.org/palimpsests#Op_Canon_of_Sherlock_Holmes_to_Elementary_SettingTransposition
:Op_Canon_of_Sherlock_Holmes_to_Elementary_SettingTransposition rdf:type owl:NamedIndividual ,
