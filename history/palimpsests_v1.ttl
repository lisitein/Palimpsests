                                                                      :targetElement :Westward_Pilgrimage_Frame ;
                                                                      :rationale "The recognizable westward-pilgrimage premise is reused as the scaffold on which the new story is built." ;
                                                                      rdfs:label "Op_Journey_to_the_West_to_A_Chinese_Odyssey_PilgrimageFrameImitation" .


###  http://example.org/palimpsests#Op_Li_Bai_Poem_to_Jin_Yong_Novel_ChivalricSpiritInheritance
:Op_Li_Bai_Poem_to_Jin_Yong_Novel_ChivalricSpiritInheritance rdf:type owl:NamedIndividual ,
                                                                      :Inheritance ;
                                                             :hasOriginalWork :Li_Bai_Poem_Xiake_Xing ;
                                                             :hasTransformativeWork :Jin_Yong_Novel_Xiake_Xing ;
                                                             :sourceElement :Chivalric_Ethos ;
                                                             :targetElement :Chivalric_Ethos ;
                                                             :rationale "The chivalrous spirit and ethos defined by the source poem are inherited -- a relationship of spiritual continuity across literary forms." ;
                                                             rdfs:label "Op_Li_Bai_Poem_to_Jin_Yong_Novel_ChivalricSpiritInheritance" .


###  http://example.org/palimpsests#Op_Li_Bai_Poem_to_Jin_Yong_Novel_CrossMediaExpansion
:Op_Li_Bai_Poem_to_Jin_Yong_Novel_CrossMediaExpansion rdf:type owl:NamedIndividual ,
                                                               :Transformation ;
                                                      :hasOriginalWork :Li_Bai_Poem_Xiake_Xing ;
                                                      :hasTransformativeWork :Jin_Yong_Novel_Xiake_Xing ;
                                                      :sourceElement :Classical_Poem ;
                                                      :targetElement :Full_Length_Wuxia_Novel ;
                                                      :rationale "A short classical poem is expanded across media into a full-length wuxia novel that interrogates what it means to be truly chivalrous." ;
                                                      rdfs:label "Op_Li_Bai_Poem_to_Jin_Yong_Novel_CrossMediaExpansion" .


###  http://example.org/palimpsests#Op_Li_Bai_Poem_to_Jin_Yong_Novel_PlotDeviceReuse
:Op_Li_Bai_Poem_to_Jin_Yong_Novel_PlotDeviceReuse rdf:type owl:NamedIndividual ,
                                                           :Imitation ;
                                                  :actsOnElement :EventSequence ;
                                                  :hasOriginalWork :Li_Bai_Poem_Xiake_Xing ;
                                                  :hasTransformativeWork :Jin_Yong_Novel_Xiake_Xing ;
                                                  :sourceElement :Poem_Text ;
                                                  :targetElement :Martial_Arts_Manual_Puzzle ;
                                                  :rationale "The verses of Li Bai's poem are reused as the central plot device: martial masters study the text hoping to unlock a legendary skill, yet only an illiterate protagonist grasps its true essence." ;
                                                  rdfs:label "Op_Li_Bai_Poem_to_Jin_Yong_Novel_PlotDeviceReuse" .


