                                                                :hasOriginalWork :Canon_of_Sherlock_Holmes ;
                                                                :hasTransformativeWork :Elementary ;
                                                                :sourceElement :Victorian_London ;
                                                                :targetElement :Contemporary_New_York ;
                                                                :rationale "Both era and place are replaced: Victorian London becomes contemporary New York City." ;
                                                                rdfs:label "Op_Canon_of_Sherlock_Holmes_to_Elementary_SettingTransposition" .


###  http://example.org/palimpsests#Op_Canon_of_Sherlock_Holmes_to_Elementary_WatsonReconception
:Op_Canon_of_Sherlock_Holmes_to_Elementary_WatsonReconception rdf:type owl:NamedIndividual ,
                                                                       :Transformation ;
                                                              :hasOriginalWork :Canon_of_Sherlock_Holmes ;
                                                              :hasTransformativeWork :Elementary ;
                                                              :sourceElement :Male_Narrator_John_Watson ;
                                                              :targetElement :Female_Sober_Companion_Joan_Watson ;
                                                              :rationale "Elementary's central creative move: Watson is reconceived as Joan Watson, changing both gender and narrative function from male chronicler to sober companion." ;
                                                              rdfs:label "Op_Canon_of_Sherlock_Holmes_to_Elementary_WatsonReconception" .


###  http://example.org/palimpsests#Op_Canon_of_Sherlock_Holmes_to_Sherlock_CharacterIntensification
