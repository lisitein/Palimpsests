                                     :hasTransformativeWork :Ulysses ;
                                     :sourceElement :Hero_Odysseus ;
                                     :targetElement :Everyman_Leopold_Bloom ;
                                     :rationale "The hero Odysseus is reimagined as the everyman Leopold Bloom, an imitative mapping of prototype onto modern figure." ;
