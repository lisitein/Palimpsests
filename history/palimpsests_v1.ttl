                                                                  :rationale "The iconic pilgrims, led by Sun Wukong, are inherited from the source." ;
                                                                  rdfs:label "Op_Journey_to_the_West_to_A_Chinese_Odyssey_CharacterInheritance" .


###  http://example.org/palimpsests#Op_Journey_to_the_West_to_A_Chinese_Odyssey_DestinySubversion
:Op_Journey_to_the_West_to_A_Chinese_Odyssey_DestinySubversion rdf:type owl:NamedIndividual ,
                                                                        :Transformation ;
                                                               :hasOriginalWork :Journey_to_the_West ;
                                                               :hasTransformativeWork :A_Chinese_Odyssey ;
                                                               :sourceElement :Ascetic_Pilgrim_Destiny ;
                                                               :targetElement :Romantic_Mortal_Tragicomedy ;
                                                               :rationale "The Monkey King's ascetic, predestined divinity is subverted into secular romantic love and a postmodern meditation on fate, recasting a religious pilgrimage as romantic tragicomedy." ;
                                                               rdfs:label "Op_Journey_to_the_West_to_A_Chinese_Odyssey_DestinySubversion" .


###  http://example.org/palimpsests#Op_Journey_to_the_West_to_A_Chinese_Odyssey_PilgrimageFrameImitation
:Op_Journey_to_the_West_to_A_Chinese_Odyssey_PilgrimageFrameImitation rdf:type owl:NamedIndividual ,
