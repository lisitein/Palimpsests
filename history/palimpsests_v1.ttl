                                                                     :sourceElement :Consulting_Detective_Assists_Police ;
                                                                     :targetElement :Consulting_Detective_Assists_Police ;
                                                                     :rationale "The structural relationship of the consulting detective assisting the official police is inherited from the source." ;
                                                                     rdfs:label "Op_Canon_of_Sherlock_Holmes_to_Elementary_ConsultingRoleInheritance" .


###  http://example.org/palimpsests#Op_Canon_of_Sherlock_Holmes_to_Elementary_DeductiveMethodImitation
