                                                          :sourceElement :Land_of_Oz_and_Cast ;
                                                          :targetElement :Land_of_Oz_and_Cast ;
                                                          :rationale "The Land of Oz, its inhabitants, and named characters are inherited from the source." ;
                                                          rdfs:label "Op_The_Wonderful_Wizard_of_Oz_to_Wicked_WorldInheritance" .


###  http://example.org/palimpsests#Op_Water_Margin_to_Jin_Ping_Mei_CharacterInheritance
:Op_Water_Margin_to_Jin_Ping_Mei_CharacterInheritance rdf:type owl:NamedIndividual ,
                                                               :Inheritance ;
                                                      :hasOriginalWork :Water_Margin ;
                                                      :hasTransformativeWork :Jin_Ping_Mei ;
                                                      :sourceElement :Core_Cast_Ximen_Pan_Wu ;
                                                      :targetElement :Core_Cast_Ximen_Pan_Wu ;
                                                      :rationale "The core cast (Xi Men Qing, Pan Jin Lian, Wu Song) is inherited directly from the source; note that Wu Song, a protagonist there, is radically marginalized here." ;
                                                      rdfs:label "Op_Water_Margin_to_Jin_Ping_Mei_CharacterInheritance" .


###  http://example.org/palimpsests#Op_Water_Margin_to_Jin_Ping_Mei_ContentDomainShift
:Op_Water_Margin_to_Jin_Ping_Mei_ContentDomainShift rdf:type owl:NamedIndividual ,
                                                             :Transformation ;
                                                    :hasOriginalWork :Water_Margin ;
                                                    :hasTransformativeWork :Jin_Ping_Mei ;
                                                    :sourceElement :Chivalric_Heroism ;
                                                    :targetElement :Domestic_Desire_and_Manners ;
                                                    :rationale "The content domain is transformed from chivalric heroism and outlaw violence into the everyday domestic world of desire, money, and social maneuvering -- the founding move of the Chinese novel of manners." ;
                                                    rdfs:label "Op_Water_Margin_to_Jin_Ping_Mei_ContentDomainShift" .


###  http://example.org/palimpsests#Op_Water_Margin_to_Jin_Ping_Mei_FocalizationShift
